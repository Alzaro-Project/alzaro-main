{
  "buildCommand": "cd TyreOps && npm install && npm run build",
  "outputDirectory": "TyreOps/dist",
  "rewrites": [
    {
      "source": "/tyreops",
      "destination": "/tyreops/index.html"
    },
    {
      "source": "/tyreops/(.*)",
      "destination": "/tyreops/index.html"
    }
  ],
  "routes": [
    {
      "src": "/tyreops/(.*)",
      "dest": "/TyreOps/dist/index.html"
    },
    {
      "src": "/tyreops",
      "dest": "/TyreOps/dist/index.html"
    }
  ]
}