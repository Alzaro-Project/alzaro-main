{
  "buildCommand": "cd TyreOps && npm install && npm run build",
  "outputDirectory": ".",
  "redirects": [
    { "source": "/TyreOps", "destination": "/tyreops", "permanent": true },
    {
      "source": "/TyreOps/:path((?!dist).*)",
      "destination": "/tyreops/:path",
      "permanent": true
    },
    { "source": "/GarageOps", "destination": "/garageops", "permanent": true },
    {
      "source": "/GarageOps/:path((?!dist).*)",
      "destination": "/garageops/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/tyreops", "destination": "/TyreOps/landing.html" },
    { "source": "/tyreops/login", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/register", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/forgot-password", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/reset-password", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/dashboard", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/invoices", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/inventory", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/customers", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/purchases", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/reports", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/vat", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/settings", "destination": "/TyreOps/dist/index.html" },
    { "source": "/tyreops/admin", "destination": "/TyreOps/dist/index.html" },

    { "source": "/garageops", "destination": "/GarageOps/index.html" },
    { "source": "/garageops/login", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/register", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/forgot-password", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/reset-password", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/dashboard", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/jobs", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/vehicles", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/parts", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/services", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/mot", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/customers", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/invoices", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/reports", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/vat", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/settings", "destination": "/TyreOps/dist/index.html" },
    { "source": "/garageops/admin", "destination": "/TyreOps/dist/index.html" },

    { "source": "/serviceops", "destination": "/ServiceOps/index.html" },
    { "source": "/ServiceOps", "destination": "/ServiceOps/index.html" },
    { "source": "/soloops", "destination": "/SoloOps/index.html" },
    { "source": "/SoloOps", "destination": "/SoloOps/index.html" },
    { "source": "/propertyops", "destination": "/PropertyOps/index.html" },
    { "source": "/PropertyOps", "destination": "/PropertyOps/index.html" },
    { "source": "/stockops", "destination": "/StockOps/index.html" },
    { "source": "/StockOps", "destination": "/StockOps/index.html" }
  ]
}
